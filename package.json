{
  "name": "sparkcode-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev":           "concurrently -n web,api -c blue,magenta \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web":       "vite",
    "dev:api":       "tsx watch server/index.ts",
    "build":         "tsc -b && vite build",
    "start":         "tsx server/index.ts",
    "preview":       "vite preview",
    "lint":          "eslint .",
    "db:generate":   "drizzle-kit generate",
    "db:push":       "drizzle-kit push",
    "db:studio":     "drizzle-kit studio",
    "import:templates": "tsx scripts/import-from-awesome.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "ali-oss": "^6.23.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.17",
    "postcss": "^8.5.14",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ali-oss": "^6.23.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
