# Backend
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://user:pass@host:port/dbname

# Aliyun OSS — only used by scripts/import-from-awesome.ts (NOT by the API server)
OSS_REGION=oss-cn-shanghai
OSS_BUCKET=sparkcode-cdn
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# CDN-bound public URL prefix; if empty, falls back to bucket-domain URL
OSS_PUBLIC_PREFIX=
